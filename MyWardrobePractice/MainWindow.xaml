<Window x:Class="MyWardrobe.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:MyWardrobe.Views"
        Title="Мій гардероб" Height="600" Width="1000">


    <Grid Background="{DynamicResource BackgroundBrush}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="196"/>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>

        <StackPanel Background="#F8BBD0">
            <Button Content="{DynamicResource Home}" Click="Home_Click" Background="#FF69B4" Margin="5"/>
            <Button Content="{DynamicResource Outfits}" Click="Outfits_Click" Background="#FF69B4" Margin="5"/>
            <Button Content="{DynamicResource Categories}" Click="Categories_Click" Background="#FF69B4" Margin="5"/>
            <Button Content="{DynamicResource Clothes}" Click="Clothes_Click" Background="#FF69B4" Margin="5"/>
            <Button Content="{DynamicResource Shoes}" Click="Shoes_Click" Background="#FF69B4" Margin="5"/>
            <Button Content="{DynamicResource Favorites}" Click="Favorites_Click" Background="#FF69B4" Margin="5"/>
            <Button Content="{DynamicResource Trash}" Click="Trash_Click" Background="#FF69B4" Margin="5"/>
            <Button Content="{DynamicResource Settings}" Click="Settings_Click" Background="#FF69B4" Margin="5"/>
        </StackPanel>

        <Frame x:Name="MainFrame" Grid.Column="1"/>

    </Grid>
</Window>