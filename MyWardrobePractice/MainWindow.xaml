<Window x:Class="MyWardrobe.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:MyWardrobe.Views"
        Title="Мій гардероб" 
        Height="600" 
        Width="1000">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250"/>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>

        <StackPanel Background="#F8BBD0">
            <Button Content="🏠 Головна" Click="Home_Click" Background="#FF69B4" Margin="5" Height="60"/>
            <Button Content="👔 Образи" Click="Outfits_Click" Background="#FF69B4" Margin="5" Height="60"/>
            <Button Content="📂 Категорії" Click="Categories_Click" Background="#FF69B4" Margin="5" Height="60"/>
            <Button Content="👕 Одяг" Click="Clothes_Click" Background="#FF69B4" Margin="5" Height="60"/>
            <Button Content="👞 Взуття" Click="Shoes_Click" Background="#FF69B4" Margin="5" Height="60"/>
            <Button Content="❤️ Улюблене" Click="Favorites_Click" Background="#FF69B4" Margin="5" Height="60"/>
            <Button Content="🗑️ Корзина" Click="Trash_Click" Background="#FF69B4" Margin="5" Height="60"/>
            <Button Content="⚙️ Налаштування" Click="Settings_Click" Background="#FF69B4" Margin="5" Height="60"/>
        </StackPanel>

        <Frame x:Name="MainFrame" Grid.Column="1"/>

    </Grid>
</Window>