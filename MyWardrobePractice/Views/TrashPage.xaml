<Page x:Class="MyWardrobe.Views.TrashPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ScrollViewer Width="800">
        <StackPanel Margin="20" Background="#FFB6C1">

            <TextBlock Text="{DynamicResource TitleTrash}" 
                       FontSize="28" 
                       FontWeight="Bold" 
                       Margin="10" 
                       HorizontalAlignment="Center"/>

            <Border Background="White" Margin="10" Padding="15">
                <ListBox x:Name="TrashList" Height="400">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Background="#FFF0F5" 
                                    Margin="5" 
                                    Padding="10" 
                                    BorderBrush="#FF69B4" 
                                    BorderThickness="1">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <Image Source="{Binding ImagePath}" 
                                           Width="60" 
                                           Height="60" 
                                           Grid.Column="0" 
                                           Margin="0,0,15,0"/>

                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="{Binding Name}" 
                                                   FontSize="18" 
                                                   FontWeight="Bold"
                                                   Foreground="#FF1493"/>
                                        <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                                            <TextBlock Text="📏 " FontSize="12"/>
                                            <TextBlock Text="{Binding Size}" FontSize="12" Margin="0,0,10,0"/>
                                            <TextBlock Text="🎨 " FontSize="12"/>
                                            <TextBlock Text="{Binding Color}" FontSize="12" Margin="0,0,10,0"/>
                                            <TextBlock Text="🌤️ " FontSize="12"/>
                                            <TextBlock Text="{Binding Season}" FontSize="12"/>
                                        </StackPanel>
                                    </StackPanel>

                                    <StackPanel Grid.Column="2" Orientation="Horizontal">
                                        <Button Content="↩️ Відновити" 
                                                Click="Restore_Click" 
                                                Width="80" 
                                                Margin="2" 
                                                Background="#4CAF50" 
                                                Foreground="White"/>
                                        <Button Content="❌" 
                                                Click="PermanentDelete_Click" 
                                                Width="40" 
                                                Margin="2" 
                                                Background="#DC143C" 
                                                Foreground="White"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Border>

        </StackPanel>
    </ScrollViewer>
</Page>