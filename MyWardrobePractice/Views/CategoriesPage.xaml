<Page x:Class="MyWardrobe.Views.CategoriesPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ScrollViewer>
        <StackPanel Margin="20" Background="{DynamicResource BackgroundBrush}">

            <TextBlock Text="{DynamicResource TitleCategories}" 
                       FontSize="28" 
                       FontWeight="Bold" 
                       Margin="10" 
                       HorizontalAlignment="Center"/>

            <StackPanel Orientation="Horizontal" 
                        HorizontalAlignment="Center" 
                        Margin="10">
                <Button Content="{DynamicResource All}" 
                        Click="Category_Click" 
                        Width="80" Margin="3" Padding="8" Background="#FF69B4"/>
                <Button Content="{DynamicResource Top}" 
                        Click="Category_Click" 
                        Width="80" Margin="3" Padding="8" Background="#FF69B4"/>
                <Button Content="{DynamicResource Bottom}" 
                        Click="Category_Click" 
                        Width="80" Margin="3" Padding="8" Background="#FF69B4"/>
                <Button Content="{DynamicResource Shoes}" 
                        Click="Category_Click" 
                        Width="80" Margin="3" Padding="8" Background="#FF69B4"/>
                <Button Content="{DynamicResource Dress}" 
                        Click="Category_Click" 
                        Width="80" Margin="3" Padding="8" Background="#FF69B4"/>
            </StackPanel>
            
            <Border Background="White" 
                    CornerRadius="15" 
                    Margin="10" 
                    Padding="15">
                <ListBox x:Name="ItemsList" Height="400">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Background="#FFF0F5" 
                                    CornerRadius="10" 
                                    Margin="5" 
                                    Padding="10">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <Image Source="{Binding ImagePath}" 
                                           Width="60" Height="60" 
                                           Grid.Column="0" 
                                           Margin="0,0,15,0"/>

                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="{Binding Name}" 
                                                   FontSize="18" 
                                                   FontWeight="Bold"/>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="📏 "/>
                                            <TextBlock Text="{Binding Size}"/>
                                            <TextBlock Text="  🎨 "/>
                                            <TextBlock Text="{Binding Color}"/>
                                            <TextBlock Text="  🌤️ "/>
                                            <TextBlock Text="{Binding Season}"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Border>

        </StackPanel>
    </ScrollViewer>
</Page>