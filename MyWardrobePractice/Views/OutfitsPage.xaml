<Page x:Class="MyWardrobe.Views.OutfitsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ScrollViewer>
        <StackPanel Margin="20" Background="{DynamicResource BackgroundBrush}">

            <TextBlock Text="{DynamicResource Outfits}" 
                       FontSize="28" 
                       FontWeight="Bold" 
                       Foreground="#FF1493" 
                       HorizontalAlignment="Center" 
                       Margin="10,0,10,20"/>

            <Border Background="White" 
                    CornerRadius="15" 
                    Margin="10" 
                    Padding="30"
                    BorderBrush="#FF69B4"
                    BorderThickness="1">
                <StackPanel HorizontalAlignment="Center">

                    <TextBlock Text="🖼️" 
                               FontSize="48" 
                               HorizontalAlignment="Center"
                               Margin="0,0,0,15"/>

                    <TextBlock Text="{DynamicResource OutfitsComingSoon}" 
                               FontSize="16" 
                               FontWeight="Bold" 
                               Foreground="#FF1493" 
                               HorizontalAlignment="Center" 
                               TextWrapping="Wrap"
                               Margin="10,0,10,20"/>
    

                    <TextBlock Text="буде доступна найближчим часом!" 
                               FontSize="14" 
                               Foreground="Gray"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,20"/>

                    <Button Content="{DynamicResource Add}" 
                            Click="CreateOutfit_Click" 
                            Width="200" 
                            Margin="10" 
                            Padding="10" 
                            Background="#FF69B4" 
                            Foreground="White" 
                            FontWeight="Bold"
                            Cursor="Hand"/>

                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</Page>