<Page
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:d="http://schemas.microsoft.com/expression/blend/2008" xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" mc:Ignorable="d" x:Class="MyWardrobe.Views.SettingsPage"
      d:DesignWidth="800" Height="358">

    <StackPanel Background="#FFB6C1" Margin="10,0,10,0">

        <TextBlock Text="{DynamicResource TitleSettings}" 
                   FontSize="28" 
                   FontWeight="Bold" 
                   Margin="10" 
                   HorizontalAlignment="Center"/>

        <Border Background="White" CornerRadius="10" Margin="10" Padding="15">
            <StackPanel>
                <TextBlock Text="{DynamicResource ThemeTitle}" 
                           FontSize="18" 
                           FontWeight="Bold" 
                           Margin="0,0,0,10"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <Button x:Name="LightThemeButton" 
                            Content="{DynamicResource LightTheme}" 
                            Width="150" 
                            Margin="5" 
                            Padding="10" 
                            Background="#FFE4E1"/>
                    <Button x:Name="DarkThemeButton" 
                            Content="{DynamicResource DarkTheme}" 
                            Width="150" 
                            Margin="5" 
                            Padding="10" 
                            Background="#2C2C2C" 
                            Foreground="White"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <Border Background="White" CornerRadius="10" Margin="10" Padding="15">
            <StackPanel>
                <TextBlock Text="{DynamicResource LanguageTitle}" 
                           FontSize="18" 
                           FontWeight="Bold" 
                           Margin="0,0,0,10"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <Button x:Name="UkrainianButton" 
                            Content="{DynamicResource Ukrainian}" 
                            Width="150" 
                            Margin="5" 
                            Padding="10" 
                            Background="#FFD700"/>
                    <Button x:Name="EnglishButton" 
                            Content="{DynamicResource English}" 
                            Width="150" 
                            Margin="5" 
                            Padding="10" 
                            Background="#4169E1" 
                            Foreground="White"/>
                </StackPanel>
            </StackPanel>
        </Border>

    </StackPanel>
</Page>