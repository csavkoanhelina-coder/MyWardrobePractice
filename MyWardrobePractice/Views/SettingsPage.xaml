<Page x:Class="MyWardrobe.Views.SettingsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <StackPanel Margin="20" Background="{DynamicResource BackgroundBrush}">

        <TextBlock Text="{DynamicResource TitleSettings}"
                   FontSize="28" 
                   FontWeight="Bold" 
                   Margin="10" 
                   HorizontalAlignment="Center"/>

        <Border Background="White" CornerRadius="10" Margin="10" Padding="15">
            <StackPanel>
                <TextBlock Text="{DynamicResource ThemeTitle}"
                           FontSize="18" 
                           FontWeight="Bold" 
                           Margin="0,0,0,10"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <Button x:Name="LightThemeButton" 
                            Content="{DynamicResource LightTheme}" 
                            Click="Light_Click"
                            Width="150" 
                            Margin="5" 
                            Padding="10" 
                            Background="#FFE4E1"/>
                    <Button x:Name="DarkThemeButton" 
                            Content="{DynamicResource DarkTheme}" 
                            Click="Dark_Click"
                            Width="150" 
                            Margin="5" 
                            Padding="10" 
                            Background="#2C2C2C" 
                            Foreground="White"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <Border Background="White" CornerRadius="10" Margin="10" Padding="15">
            <StackPanel>
                <TextBlock Text="{DynamicResource LanguageTitle}" 
                           FontSize="18" 
                           FontWeight="Bold" 
                           Margin="0,0,0,10"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <Button x:Name="UkrainianButton" 
                            Content="{DynamicResource Ukrainian}" 
                            Click="UA_Click"
                            Width="150" 
                            Margin="5" 
                            Padding="10" 
                            Background="#FFD700"/>
                    <Button x:Name="EnglishButton" 
                            Content="{DynamicResource English}" 
                            Click="EN_Click"
                            Width="150" 
                            Margin="5" 
                            Padding="10" 
                            Background="#4169E1" 
                            Foreground="White"/>
                </StackPanel>
            </StackPanel>
        </Border>

    </StackPanel>
</Page>