<Window x:Class="MyWardrobe.Views.ViewOutfitWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource ViewOutfitTitle}" 
        Height="500" 
        Width="600"
        WindowStartupLocation="CenterOwner">

    <Window.Background>
        <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
            <GradientStop Color="#FFB6C1" Offset="0"/>
            <GradientStop Color="#FF69B4" Offset="1"/>
        </LinearGradientBrush>
    </Window.Background>

    <Border Background="White" CornerRadius="15" Margin="15" Padding="20">
        <StackPanel>

            <TextBlock x:Name="TitleText" 
                       FontSize="24" 
                       FontWeight="Bold" 
                       Foreground="#FF1493" 
                       HorizontalAlignment="Center" 
                       Margin="0,0,0,10"/>

            <TextBlock x:Name="DescriptionText" 
                       FontSize="14" 
                       Foreground="Gray" 
                       HorizontalAlignment="Center" 
                       TextWrapping="Wrap"
                       Margin="0,0,0,5"/>

            <TextBlock x:Name="DateText" 
                       FontSize="12" 
                       Foreground="Gray" 
                       HorizontalAlignment="Center" 
                       Margin="0,0,0,20"/>

            <Border Background="#FFF0F5" CornerRadius="10" Padding="15" Margin="0,0,0,10">
                <StackPanel>
                    <TextBlock Text="{DynamicResource ItemsInOutfit}" 
                               FontSize="16" 
                               FontWeight="Bold" 
                               Foreground="#FF1493" 
                               Margin="0,0,0,10"/>
                    <ListBox x:Name="ItemsList" Height="250">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#FFE4E1" Margin="3" Padding="8" CornerRadius="5">
                                    <StackPanel Orientation="Horizontal">
                                        <Image Source="{Binding ImagePath}" Width="50" Height="50" Margin="0,0,15,0"/>
                                        <StackPanel>
                                            <TextBlock Text="{Binding Name}" FontSize="16" FontWeight="Bold"/>
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="{Binding Type}" FontSize="12" Foreground="Gray" Width="60"/>
                                                <TextBlock Text="{Binding Color}" FontSize="12" Foreground="Gray" Width="60"/>
                                                <TextBlock Text="{Binding Size}" FontSize="12" Foreground="Gray"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </StackPanel>
            </Border>

            <Button Content="{DynamicResource Close}" 
                    Click="Close_Click" 
                    Background="#FF69B4" 
                    Foreground="White" 
                    FontSize="14" 
                    FontWeight="Bold" 
                    Padding="10" 
                    Width="120" 
                    HorizontalAlignment="Center"/>

        </StackPanel>
    </Border>
</Window>