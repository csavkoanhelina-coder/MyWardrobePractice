<Page x:Class="MyWardrobe.Views.ClothesPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ScrollViewer>
        <StackPanel Margin="20" Background="{DynamicResource BackgroundBrush}">

            <TextBlock Text="{DynamicResource TitleClothes}" 
                       FontSize="28" 
                       FontWeight="Bold" 
                       Margin="10" 
                       HorizontalAlignment="Center"/>

            <Button Content="{DynamicResource Add}" 
                    Click="OpenAddWindow_Click" 
                    Width="200" 
                    Margin="10" 
                    Padding="10" 
                    Background="#4CAF50" 
                    Foreground="White" 
                    FontWeight="Bold"/>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="10">
                <TextBlock Text="🔍 Фільтр:" VerticalAlignment="Center" Margin="5" FontWeight="Bold" Foreground="#FF1493"/>

                <ComboBox x:Name="ColorFilter" Width="120" Margin="5" SelectionChanged="Filter_Changed">
                    <ComboBoxItem Content="🎨 Всі кольори"/>
                    <ComboBoxItem Content="Чорний"/>
                    <ComboBoxItem Content="Білий"/>
                    <ComboBoxItem Content="Синій"/>
                    <ComboBoxItem Content="Рожевий"/>
                    <ComboBoxItem Content="Жовтий"/>
                    <ComboBoxItem Content="Бежевий"/>
                    <ComboBoxItem Content="Коричневий"/>
                    <ComboBoxItem Content="Темно-зелений"/>
                </ComboBox>

                <ComboBox x:Name="SeasonFilter" Width="120" Margin="5" SelectionChanged="Filter_Changed">
                    <ComboBoxItem Content="🌤️ Всі сезони"/>
                    <ComboBoxItem Content="🌸 Весна"/>
                    <ComboBoxItem Content="☀️ Літо"/>
                    <ComboBoxItem Content="🍂 Осінь"/>
                    <ComboBoxItem Content="❄️ Зима"/>
                </ComboBox>
            </StackPanel>

            <Border Background="White" 
                    Margin="10" 
                    Padding="15">

                <ListBox x:Name="ClothesList" Height="450">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Background="#FFF0F5" 
                                    Margin="5" 
                                    Padding="10" 
                                    BorderBrush="#FF69B4" 
                                    BorderThickness="1">

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <Image Source="{Binding ImagePath}" 
                                           Width="70" 
                                           Height="70" 
                                           Grid.Column="0" 
                                           Margin="0,0,15,0" />

                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="{Binding Name}" 
                                                   FontSize="18" 
                                                   FontWeight="Bold" 
                                                   Foreground="#FF1493"/>
                                        <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                                            <Border Background="#FFE4E1" Padding="5,2">
                                                <TextBlock FontSize="12">
                                                    <Run Text="📏 "/><Run Text="{Binding Size}"/>
                                                </TextBlock>
                                            </Border>
                                            <Border Background="#FFE4E1" Padding="5,2" Margin="5,0">
                                                <TextBlock FontSize="12">
                                                    <Run Text="🎨 "/><Run Text="{Binding Color}"/>
                                                </TextBlock>
                                            </Border>
                                            <Border Background="#FFE4E1" Padding="5,2">
                                                <TextBlock FontSize="12">
                                                    <Run Text="🌤️ "/><Run Text="{Binding Season}"/>
                                                </TextBlock>
                                            </Border>
                                        </StackPanel>
                                        <TextBlock Text="{Binding Type}" 
                                                   FontSize="12" 
                                                   Foreground="Gray" 
                                                   Margin="0,5,0,0"/>
                                    </StackPanel>

                                    <StackPanel Grid.Column="2" 
                                                Orientation="Horizontal" 
                                                VerticalAlignment="Center">
                                        <Button Content="✏️" 
                                                Click="Edit_Click" 
                                                Width="45" 
                                                Height="45" 
                                                Margin="5" 
                                                Background="#FFA500" 
                                                Foreground="White" 
                                                FontSize="16" 
                                                ToolTip="Редагувати"/>
                                        <Button Content="❤️" 
                                                Click="Favorite_Click" 
                                                Width="45" 
                                                Height="45" 
                                                Margin="5" 
                                                Background="#FF69B4" 
                                                Foreground="White" 
                                                FontSize="16" 
                                                ToolTip="Улюблене"/>
                                        <Button Content="🗑️" 
                                                Click="Delete_Click" 
                                                Width="45" 
                                                Height="45" 
                                                Margin="5" 
                                                Background="#DC143C" 
                                                Foreground="White" 
                                                FontSize="16" 
                                                ToolTip="Видалити"/>
                                    </StackPanel>

                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Border>

            <TextBlock Text="{DynamicResource Tip}" 
                       FontSize="11" 
                       Foreground="Gray" 
                       HorizontalAlignment="Center" 
                       Margin="10"/>

        </StackPanel>
    </ScrollViewer>
</Page>