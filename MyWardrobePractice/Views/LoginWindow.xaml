<Window x:Class="MyWardrobe.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Вхід" 
        Height="500" 
        Width="400"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">

    <Window.Background>
        <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
            <GradientStop Color="#FFB6C1" Offset="0"/>
            <GradientStop Color="#FF69B4" Offset="1"/>
        </LinearGradientBrush>
    </Window.Background>

    <Border Background="White" CornerRadius="15" Margin="15" Padding="20">
        <StackPanel VerticalAlignment="Center">

            <TextBlock Text="👗" 
                       FontSize="50" 
                       HorizontalAlignment="Center" 
                       Margin="0,0,0,10"/>

            <TextBlock Text="Мій гардероб" 
                       FontSize="24" 
                       FontWeight="Bold" 
                       Foreground="#FF1493" 
                       HorizontalAlignment="Center" 
                       Margin="0,0,0,5"/>

            <TextBlock Text="Увійдіть у свій акаунт" 
                       FontSize="12" 
                       Foreground="Gray" 
                       HorizontalAlignment="Center" 
                       Margin="0,0,0,20"/>

            <TextBlock Text="👤 Логін:" FontSize="14" FontWeight="Bold" Margin="0,5,0,2" Foreground="#333"/>
            <TextBox x:Name="LoginBox" 
                     Padding="10" 
                     FontSize="14"
                     Background="#FFF0F5"
                     BorderBrush="#FFB6C1"
                     BorderThickness="1"/>

            <TextBlock Text="🔒 Пароль:" FontSize="14" FontWeight="Bold" Margin="0,10,0,2" Foreground="#333"/>
            <PasswordBox x:Name="PasswordBox" 
                         Padding="10" 
                         FontSize="14"
                         Background="#FFF0F5"
                         BorderBrush="#FFB6C1"
                         BorderThickness="1"/>

            <Button Content="🔑 Увійти" 
                    Click="Login_Click" 
                    Background="#FF69B4" 
                    Foreground="White" 
                    FontSize="14" 
                    FontWeight="Bold"
                    Padding="10" 
                    Margin="0,20,0,5"
                    Cursor="Hand"
                    Height="40"/>

            <TextBlock HorizontalAlignment="Center" Margin="0,10,0,0">
                <Run Text="Немає акаунту?" Foreground="Gray" FontSize="12"/>
                <Run Text=" "/>
                <Hyperlink Click="GoToRegister_Click" Foreground="#FF69B4" FontSize="12">
                    <Run Text="Зареєструватися"/>
                </Hyperlink>
            </TextBlock>

        </StackPanel>
    </Border>
</Window>