<Window x:Class="MyWardrobe.Views.CustomMessageBox"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Підтвердження" 
        Height="270" 
        Width="400"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False">

    <Window.Background>
        <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
            <GradientStop Color="#FFB6C1" Offset="0"/>
            <GradientStop Color="#FF69B4" Offset="1"/>
        </LinearGradientBrush>
    </Window.Background>

    <Border Background="White" CornerRadius="15" Margin="15" Padding="20">
        <StackPanel>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,15">
                <TextBlock x:Name="IconText" Text="❓" FontSize="40" Margin="0,0,10,0"/>
                <TextBlock x:Name="TitleText" Text="Підтвердження" FontSize="20" FontWeight="Bold" Foreground="#FF1493" VerticalAlignment="Center"/>
            </StackPanel>

            <TextBlock x:Name="MessageText" 
                       Text="Текст повідомлення" 
                       FontSize="14" 
                       Foreground="#333333" 
                       TextWrapping="Wrap" 
                       TextAlignment="Center"
                       Margin="0,0,0,20"/>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <Button x:Name="YesButton" 
                        Content="Так" 
                        Width="100" 
                        Height="35" 
                        Margin="5" 
                        Background="#4CAF50" 
                        Foreground="White" 
                        FontSize="14" 
                        FontWeight="Bold"
                        Cursor="Hand"
                        Click="YesButton_Click"/>

                <Button x:Name="NoButton" 
                        Content="Ні" 
                        Width="100" 
                        Height="35" 
                        Margin="5" 
                        Background="#DC143C" 
                        Foreground="White" 
                        FontSize="14" 
                        FontWeight="Bold"
                        Cursor="Hand"
                        Click="NoButton_Click"/>

                <Button x:Name="OkButton" 
                        Content="OK" 
                        Width="100" 
                        Height="35" 
                        Margin="5" 
                        Background="#FF69B4" 
                        Foreground="White" 
                        FontSize="14" 
                        FontWeight="Bold"
                        Cursor="Hand"
                        Click="OkButton_Click"
                        Visibility="Collapsed"/>
            </StackPanel>

        </StackPanel>
    </Border>
</Window>