<Page
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:d="http://schemas.microsoft.com/expression/blend/2008" xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" mc:Ignorable="d" x:Class="MyWardrobe.Views.FavoritesPage"
      d:DesignWidth="800">

    <ScrollViewer>
        <StackPanel Margin="20" Background="#FFB6C1">

            <TextBlock Text="{DynamicResource TitleFavorites}" 
                       FontSize="28" 
                       FontWeight="Bold" 
                       Margin="10" 
                       HorizontalAlignment="Center"/>

            <Border Background="White" Margin="10" Padding="15">
                <ListBox x:Name="FavoritesList" Height="400">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Background="#FFF0F5" 
                                    Margin="5" 
                                    Padding="10" 
                                    BorderBrush="#FF69B4" 
                                    BorderThickness="1">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <Image Source="{Binding ImagePath}" 
                                           Width="60" 
                                           Height="60" 
                                           Grid.Column="0" 
                                           Margin="0,0,15,0"/>

                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="{Binding Name}" 
                                                   FontSize="18" 
                                                   FontWeight="Bold"
                                                   Foreground="#FF1493"/>
                                        <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                                            <TextBlock Text="📏 " FontSize="12"/>
                                            <TextBlock Text="{Binding Size}" FontSize="12" Margin="0,0,10,0"/>
                                            <TextBlock Text="🎨 " FontSize="12"/>
                                            <TextBlock Text="{Binding Color}" FontSize="12" Margin="0,0,10,0"/>
                                            <TextBlock Text="🌤️ " FontSize="12"/>
                                            <TextBlock Text="{Binding Season}" FontSize="12"/>
                                        </StackPanel>
                                    </StackPanel>

                                    <Button Grid.Column="2" 
                                            Content="❤️" 
                                            Click="RemoveFavorite_Click" 
                                            Width="40" 
                                            Height="40" 
                                            Background="#FF69B4" 
                                            Foreground="White" 
                                            FontSize="16"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Border>

        </StackPanel>
    </ScrollViewer>
</Page>