<Page x:Class="MyWardrobe.Views.StatisticsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ScrollViewer Width="700">
        <StackPanel Margin="20" Background="{DynamicResource BackgroundBrush}">

            <TextBlock Text="{DynamicResource Statistics}" 
                       FontSize="28" 
                       FontWeight="Bold" 
                       Foreground="#FF1493" 
                       HorizontalAlignment="Center" 
                       Margin="10,0,10,20"/>

            <Border Background="White" CornerRadius="15" Margin="10" Padding="20">
                <StackPanel>

                    <TextBlock x:Name="TotalCount" 
                               FontSize="20" 
                               FontWeight="Bold" 
                               Foreground="#FF1493"
                               Margin="0,5"
                               HorizontalAlignment="Center"/>

                    <Line X1="0" Y1="0" X2="1" Y2="0" Stroke="#FFB6C1" StrokeThickness="1" Margin="0,10,0,10"/>

                    <TextBlock Text="{DynamicResource ByCategory}" FontSize="16" FontWeight="Bold" Margin="0,10,0,5"/>
                    <TextBlock x:Name="TopCount" FontSize="14" Margin="0,3"/>
                    <TextBlock x:Name="BottomCount" FontSize="14" Margin="0,3"/>
                    <TextBlock x:Name="DressCount" FontSize="14" Margin="0,3"/>
                    <TextBlock x:Name="ShoesCount" FontSize="14" Margin="0,3"/>

                    <Line X1="0" Y1="0" X2="1" Y2="0" Stroke="#FFB6C1" StrokeThickness="1" Margin="0,10,0,10"/>

                    <TextBlock Text="{DynamicResource FavoritesTitle}" FontSize="16" FontWeight="Bold" Margin="0,10,0,5"/>
                    <TextBlock x:Name="FavoritesCount" FontSize="14" Margin="0,3"/>

                    <Line X1="0" Y1="0" X2="1" Y2="0" Stroke="#FFB6C1" StrokeThickness="1" Margin="0,10,0,10"/>

                    <TextBlock Text="{DynamicResource BySeason}" FontSize="16" FontWeight="Bold" Margin="0,10,0,5"/>
                    <TextBlock x:Name="SpringCount" FontSize="14" Margin="0,3"/>
                    <TextBlock x:Name="SummerCount" FontSize="14" Margin="0,3"/>
                    <TextBlock x:Name="AutumnCount" FontSize="14" Margin="0,3"/>
                    <TextBlock x:Name="WinterCount" FontSize="14" Margin="0,3"/>

                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</Page>