<Page
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:d="http://schemas.microsoft.com/expression/blend/2008" xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" mc:Ignorable="d" x:Class="MyWardrobe.Views.HomePage"
      d:DesignWidth="1247.341">

    <ScrollViewer>
        <StackPanel Margin="20" Background="#FFB6C1" Width="1014">

            <TextBlock Text="{DynamicResource TitleHome}" 
                       FontSize="28" 
                       FontWeight="Bold" 
                       Foreground="#FF1493" 
                       HorizontalAlignment="Center" 
                       Margin="10,0,10,20"/>

            <Border Background="White" 
                    Margin="10" 
                    Padding="15"
                    BorderBrush="#FF69B4"
                    BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="{DynamicResource Search}" 
                               FontSize="18" 
                               FontWeight="Bold" 
                               Foreground="#FF1493"
                               Margin="0,0,0,10"/>

                    <StackPanel Orientation="Horizontal">
                        <TextBox x:Name="SearchBox" 
                                 Width="400" 
                                 Margin="5" 
                                 Padding="10" 
                                 FontSize="14"
                                 Background="#FFF0F5"
                                 BorderBrush="#FFB6C1"
                                 BorderThickness="1"/>
                        <Button Content="🔍" 
                                Click="Search_Click" 
                                Width="169" 
                                Margin="5" 
                                Padding="10" 
                                Background="#FF69B4" 
                                Foreground="White" 
                                FontWeight="Bold"/>
                    </StackPanel>

                    <TextBlock Text="{DynamicResource SearchResult}" 
                               FontSize="14" 
                               FontWeight="Bold" 
                               Margin="0,15,0,5"
                               Foreground="#FF1493"/>

                    <ListBox x:Name="ResultList" 
                             Height="150" 
                             Margin="5"
                             Background="#FFF0F5"
                             BorderBrush="#FFB6C1">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#FFE4E1" 
                                        Margin="5" 
                                        Padding="8">
                                    <StackPanel Orientation="Horizontal">
                                        <Image Source="{Binding ImagePath}" 
                                               Width="40" 
                                               Height="40" 
                                               Margin="0,0,10,0"/>
                                        <StackPanel>
                                            <TextBlock Text="{Binding Name}" 
                                                       FontSize="14" 
                                                       FontWeight="Bold"/>
                                            <TextBlock Text="{Binding Type}" 
                                                       FontSize="11" 
                                                       Foreground="Gray"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </StackPanel>
            </Border>

            <Border Background="White" 
                    Margin="10" 
                    Padding="15"
                    BorderBrush="#FF69B4"
                    BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="{DynamicResource MyCollection}" 
                               FontSize="18" 
                               FontWeight="Bold" 
                               Foreground="#FF1493"
                               Margin="0,0,0,10"/>

                    <ListBox x:Name="ItemsList" 
                             Height="350" 
                             Margin="5"
                             Background="#FFF0F5"
                             BorderBrush="#FFB6C1">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#FFE4E1" 
                                        Margin="5" 
                                        Padding="10">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <Image Source="{Binding ImagePath}" 
                                               Width="50" 
                                               Height="50" 
                                               Grid.Column="0"
                                               Margin="0,0,15,0"/>

                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="{Binding Name}" 
                                                       FontSize="16" 
                                                       FontWeight="Bold"
                                                       Foreground="#FF1493"/>
                                            <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                                                <TextBlock Text="📏 " FontSize="12"/>
                                                <TextBlock Text="{Binding Size}" FontSize="12" Margin="0,0,10,0"/>
                                                <TextBlock Text="🎨 " FontSize="12"/>
                                                <TextBlock Text="{Binding Color}" FontSize="12" Margin="0,0,10,0"/>
                                                <TextBlock Text="🌤️ " FontSize="12"/>
                                                <TextBlock Text="{Binding Season}" FontSize="12"/>
                                            </StackPanel>
                                            <TextBlock Text="{Binding Type}" 
                                                       FontSize="11" 
                                                       Foreground="Gray"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <TextBlock x:Name="CountText" 
                               FontSize="11" 
                               Foreground="Gray" 
                               HorizontalAlignment="Right" 
                               Margin="0,5,0,0"/>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</Page>