<Window x:Class="MyWardrobe.Views.AddClothesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="➕ Додати новий одяг" 
        Height="800" 
        Width="450"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">

    <Window.Background>
        <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
            <GradientStop Color="#FFB6C1" Offset="0"/>
            <GradientStop Color="#FF69B4" Offset="1"/>
        </LinearGradientBrush>
    </Window.Background>

    <Border Background="White" CornerRadius="20" Margin="15" Padding="20">
        <StackPanel>

            <TextBlock Text="{DynamicResource Add}" 
                       FontSize="24" 
                       FontWeight="Bold" 
                       Foreground="#FF1493" 
                       HorizontalAlignment="Center" 
                       Margin="0,0,0,20"/>

            <TextBlock Text="{DynamicResource Name}" 
                       FontSize="14" 
                       FontWeight="Bold" 
                       Margin="0,5,0,2"/>
            <TextBox x:Name="NameBox" 
                     Padding="10" 
                     FontSize="14" 
                     Background="#FFF0F5" 
                     BorderBrush="#FFB6C1" 
                     BorderThickness="1"/>

            <TextBlock Text="{DynamicResource Size}" 
                       FontSize="14" 
                       FontWeight="Bold" 
                       Margin="0,10,0,2"/>
            <TextBox x:Name="SizeBox" 
                     Padding="10" 
                     FontSize="14" 
                     Background="#FFF0F5" 
                     BorderBrush="#FFB6C1" 
                     BorderThickness="1"/>

            <TextBlock Text="{DynamicResource Color}" 
                       FontSize="14" 
                       FontWeight="Bold" 
                       Margin="0,10,0,2"/>
            <TextBox x:Name="ColorBox" 
                     Padding="10" 
                     FontSize="14" 
                     Background="#FFF0F5" 
                     BorderBrush="#FFB6C1" 
                     BorderThickness="1"/>

            <TextBlock Text="{DynamicResource Type}" 
                       FontSize="14" 
                       FontWeight="Bold" 
                       Margin="0,10,0,2"/>
            <ComboBox x:Name="TypeBox" 
                      Padding="8" 
                      FontSize="14" 
                      Background="#FFF0F5" 
                      BorderBrush="#FFB6C1"
                      SelectedIndex="0">
                <ComboBoxItem Content="{DynamicResource Top}"/>
                <ComboBoxItem Content="{DynamicResource Bottom}"/>
                <ComboBoxItem Content="{DynamicResource Dress}"/>
                <ComboBoxItem Content="{DynamicResource Shoes}"/>
            </ComboBox>

            <TextBlock Text="{DynamicResource Season}" 
                       FontSize="14" 
                       FontWeight="Bold" 
                       Margin="0,10,0,2"/>
            <ComboBox x:Name="SeasonBox" 
                      Padding="8" 
                      FontSize="14" 
                      Background="#FFF0F5" 
                      BorderBrush="#FFB6C1"
                      SelectedIndex="0">
                <ComboBoxItem Content="{DynamicResource Spring}"/>
                <ComboBoxItem Content="{DynamicResource Summer}"/>
                <ComboBoxItem Content="{DynamicResource Autumn}"/>
                <ComboBoxItem Content="{DynamicResource Winter}"/>
            </ComboBox>

            <Button Content="{DynamicResource ChooseImage}" 
                    Click="ChooseImage_Click" 
                    Background="#FF69B4" 
                    Foreground="White" 
                    FontSize="14" 
                    FontWeight="Bold"
                    Padding="10" 
                    Margin="0,15,0,5"/>

            <Border Background="#FFF0F5" 
                    CornerRadius="10" 
                    BorderBrush="#FFB6C1" 
                    BorderThickness="1"
                    Padding="10"
                    Margin="0,5,0,10">
                <StackPanel>
                    <TextBlock Text="📷 Попередній перегляд:" FontSize="12" Foreground="Gray" Margin="0,0,0,5"/>
                    <Image x:Name="PreviewImage" 
                           Width="100" 
                           Height="100" 
                           Stretch="Uniform"
                           HorizontalAlignment="Center"/>
                    <TextBlock x:Name="ImagePathText" 
                               Text="Фото не вибрано" 
                               FontSize="10" 
                               Foreground="Gray" 
                               HorizontalAlignment="Center"
                               Margin="0,5,0,0"/>
                </StackPanel>
            </Border>
            
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10,0,0">
                <Button Content="{DynamicResource Save}" 
                        Click="Save_Click" 
                        Background="#4CAF50" 
                        Foreground="White" 
                        FontSize="14" 
                        FontWeight="Bold"
                        Padding="20,10" 
                        Width="120"
                        Margin="5"/>

                <Button Content="{DynamicResource Cancel}" 
                        Click="Cancel_Click" 
                        Background="#DC143C" 
                        Foreground="White" 
                        FontSize="14" 
                        FontWeight="Bold"
                        Padding="20,10" 
                        Width="120"
                        Margin="5"/>
            </StackPanel>

        </StackPanel>
    </Border>
</Window>